{
  "name": "claudelift",
  "version": "0.5.0",
  "description": "Desktop GUI for the cowork_export.py engine - export, import, seed, and Notion-publish Claude Cowork tasks",
  "main": "./out/main/index.js",
  "author": "EditMyPodcast",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:mcp": "node scripts/build-mcp.mjs",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "gen:icons": "node ../scripts/gen-icons.mjs",
    "dist": "powershell -ExecutionPolicy Bypass -File ../scripts/dist.ps1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tanstack/react-virtual": "^3.14.6",
    "@tryfabric/martian": "^1.2.4",
    "archiver": "^7.0.1",
    "chokidar": "^4.0.3",
    "electron-store": "^10.1.0",
    "p-queue": "^9.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "daisyui": "^5.6.18",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.28.1",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  }
}
